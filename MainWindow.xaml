<Window x:Class="ObeliskLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Obelisk Launcher"
        Width="1420"
        Height="840"
        MinWidth="1180"
        MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Background="#111214">
    <Window.Resources>
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#111214"/>
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#17181C"/>
        <SolidColorBrush x:Key="LineBrush" Color="#30333B"/>
        <SolidColorBrush x:Key="TextBrush" Color="#EEF1F4"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#9EA6B2"/>
        <SolidColorBrush x:Key="DimTextBrush" Color="#717A86"/>

        <Style x:Key="BaseButton" TargetType="{x:Type Button}">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="#22252C"/>
            <Setter Property="BorderBrush" Value="#3A3E48"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#2B2E36"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#545B68"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#191B20"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#68717C"/>
                                <Setter TargetName="Chrome" Property="Background" Value="#191B20"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#282B32"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolbarButton" BasedOn="{StaticResource BaseButton}" TargetType="{x:Type Button}">
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>

        <Style x:Key="DangerToolbarButton" BasedOn="{StaticResource ToolbarButton}" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="#48171B"/>
            <Setter Property="BorderBrush" Value="#E25763"/>
            <Setter Property="Foreground" Value="#FFE5E7"/>
        </Style>

        <Style x:Key="AccentToolbarButton" BasedOn="{StaticResource ToolbarButton}" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="#18463D"/>
            <Setter Property="BorderBrush" Value="#3AAE93"/>
            <Setter Property="Foreground" Value="#E8FFF9"/>
        </Style>

        <Style x:Key="NavButton" BasedOn="{StaticResource BaseButton}" TargetType="{x:Type Button}">
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="FontWeight" Value="Normal"/>
        </Style>

        <Style x:Key="SelectedNavButton" BasedOn="{StaticResource NavButton}" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="#263238"/>
            <Setter Property="BorderBrush" Value="#3A8C7F"/>
            <Setter Property="Foreground" Value="#F3FFFB"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="InstanceActionButton" BasedOn="{StaticResource BaseButton}" TargetType="{x:Type Button}">
            <Setter Property="MinWidth" Value="88"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="8,5,0,5"/>
        </Style>

        <Style x:Key="StartButton" BasedOn="{StaticResource InstanceActionButton}" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="#173E33"/>
            <Setter Property="BorderBrush" Value="#3AAE72"/>
        </Style>

        <Style x:Key="StopButton" BasedOn="{StaticResource InstanceActionButton}" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="#3B2424"/>
            <Setter Property="BorderBrush" Value="#C65A52"/>
        </Style>

        <Style x:Key="GameChoiceButton" BasedOn="{StaticResource BaseButton}" TargetType="{x:Type Button}">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Background" Value="#202329"/>
            <Setter Property="BorderBrush" Value="#3E444D"/>
            <Setter Property="Height" Value="116"/>
        </Style>

        <Style x:Key="SettingsTextBox" TargetType="{x:Type TextBox}">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="#111318"/>
            <Setter Property="BorderBrush" Value="#3A3E48"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="{StaticResource TextBrush}"/>
            <Setter Property="SelectionBrush" Value="#3A8C7F"/>
        </Style>

        <Style x:Key="SettingsPasswordBox" TargetType="{x:Type PasswordBox}">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="#111318"/>
            <Setter Property="BorderBrush" Value="#3A3E48"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="{StaticResource TextBrush}"/>
            <Setter Property="SelectionBrush" Value="#3A8C7F"/>
        </Style>

        <Style x:Key="SettingsCheckBox" TargetType="{x:Type CheckBox}">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,18,10"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="46"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#17181C"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Left"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="16,0,0,0">
                    <TextBlock Text="Obelisk Launcher"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="15"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               Margin="0,0,18,0"/>
                    <Button x:Name="CurrentGameButton"
                            Content="ARK: Ascended"
                            Style="{StaticResource AccentToolbarButton}"
                            Click="ShowGamePicker_Click"/>
                    <Button x:Name="ExeButton"
                            Content="EXE НЕ УКАЗАН"
                            Style="{StaticResource DangerToolbarButton}"
                            Click="ChooseExe_Click"/>
                    <Button Content="Новый кластер"
                            Style="{StaticResource ToolbarButton}"
                            IsEnabled="{Binding CanCreateCluster}"
                            ToolTip="Пока приложение работает с одним кластером."
                            Click="CreateCluster_Click"/>
                    <Button Content="Добавить карту"
                            Style="{StaticResource ToolbarButton}"
                            IsEnabled="{Binding HasCluster}"
                            Click="AddMap_Click"/>
                    <Button Content="Импорт .bat"
                            Style="{StaticResource ToolbarButton}"
                            IsEnabled="{Binding HasCluster}"
                            Click="ImportBat_Click"/>
                    <Button Content="Обновить статус"
                            Style="{StaticResource ToolbarButton}"
                            Click="RefreshStatuses_Click"/>
                    <Button Content="Настройки"
                            Style="{StaticResource ToolbarButton}"
                            IsEnabled="{Binding HasCluster}"
                            Click="EditFirstCluster_Click"/>
                    <Button Content="Настройки игры"
                            Style="{StaticResource ToolbarButton}"
                            Click="OpenGameSettings_Click"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,16,0">
                    <Ellipse x:Name="ExeStatusDot" Width="8" Height="8" Fill="#E25763" Margin="0,0,8,0"/>
                    <TextBlock x:Name="ExeStatusText"
                               Text="Путь к серверу не настроен"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="12"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="232"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource PanelBackgroundBrush}"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="0,0,1,0">
                <StackPanel Margin="14,18">
                    <TextBlock Text="Рабочая область"
                               Foreground="{StaticResource DimTextBrush}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Margin="2,0,0,10"/>
                    <Button Content="Кластеры" Style="{StaticResource SelectedNavButton}"/>
                    <Button Content="Карты" Style="{StaticResource NavButton}"/>
                    <Button Content="Шаблоны запуска" Style="{StaticResource NavButton}"/>
                    <Button Content="RCON команды" Style="{StaticResource NavButton}"/>
                    <Button Content="Логи" Style="{StaticResource NavButton}"/>

                    <Border Height="1"
                            Background="{StaticResource LineBrush}"
                            Margin="0,12,0,16"/>

                    <TextBlock Text="Сводка"
                               Foreground="{StaticResource DimTextBrush}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Margin="2,0,0,12"/>

                    <Grid Margin="2,0,2,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Кластеры" Foreground="{StaticResource MutedTextBrush}" FontSize="13"/>
                        <TextBlock Grid.Column="1" Text="{Binding ClusterCountText}" Foreground="{StaticResource TextBrush}" FontSize="13" FontWeight="SemiBold"/>
                    </Grid>
                    <Grid Margin="2,0,2,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Карт запущено" Foreground="{StaticResource MutedTextBrush}" FontSize="13"/>
                        <TextBlock Grid.Column="1" Text="{Binding OnlineMapsText}" Foreground="#6EE7B7" FontSize="13" FontWeight="SemiBold"/>
                    </Grid>
                    <Border Background="#20191B"
                            BorderBrush="#553035"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12"
                            Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock Text="ArkAscendedServer.exe"
                                       Foreground="#FFE5E7"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"/>
                            <TextBlock x:Name="ExeHintText"
                                       Text="Не указан. Кнопка сверху горит красным, пока путь пустой."
                                       Foreground="#CE9CA1"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="104"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="#131417"
                        BorderBrush="{StaticResource LineBrush}"
                        BorderThickness="0,0,0,1">
                    <DockPanel Margin="28,20,28,18">
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Text="Кластеры серверов"
                                       Foreground="{StaticResource TextBrush}"
                                       FontSize="24"
                                       FontWeight="Bold"/>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <TextBlock Text="Выбрана игра:" Foreground="{StaticResource MutedTextBrush}" FontSize="13"/>
                                <TextBlock x:Name="SelectedGameName"
                                           Text="ARK Survival Ascended"
                                           Foreground="#6EE7B7"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Margin="6,0,0,0"/>
                                <TextBlock Text="  /  управление выделенными серверами" Foreground="{StaticResource DimTextBrush}" FontSize="13"/>
                            </StackPanel>
                            <TextBlock x:Name="DemoStatusText"
                                       Text="Готово к запуску карт после выбора ArkAscendedServer.exe."
                                       Foreground="{StaticResource DimTextBrush}"
                                       FontSize="12"
                                       Margin="0,6,0,0"/>
                        </StackPanel>

                        <StackPanel DockPanel.Dock="Right"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Border Background="#1D1F25"
                                    BorderBrush="{StaticResource LineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="14,9">
                                <StackPanel>
                                    <TextBlock Text="СТАТУС" Foreground="{StaticResource DimTextBrush}" FontSize="10" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding HeaderStatusText}" Foreground="{Binding HeaderStatusBrush}" FontSize="18" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Clusters}"
                                  Margin="28,22,28,32">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,0,26">
                                    <DockPanel Margin="0,0,0,10">
                                        <TextBlock DockPanel.Dock="Left"
                                                   Text="{Binding Title}"
                                                   Foreground="{StaticResource TextBrush}"
                                                   FontSize="20"
                                                   FontWeight="Bold"
                                                   VerticalAlignment="Center"/>
                                        <Button DockPanel.Dock="Left"
                                                Width="32"
                                                Height="28"
                                                Padding="7"
                                                Margin="10,0,0,0"
                                                Style="{StaticResource InstanceActionButton}"
                                                ToolTip="Изменить настройки кластера"
                                                Tag="{Binding}"
                                                Click="EditCluster_Click">
                                            <Viewbox Width="14" Height="14">
                                                <Canvas Width="24" Height="24">
                                                    <Path Data="M4,16 L3,21 L8,20 L19,9 L15,5 Z"
                                                          Stroke="{StaticResource TextBrush}"
                                                          StrokeThickness="2"
                                                          StrokeLineJoin="Round"
                                                          Fill="Transparent"/>
                                                    <Path Data="M14,6 L18,10"
                                                          Stroke="{StaticResource TextBrush}"
                                                          StrokeThickness="2"
                                                          StrokeLineJoin="Round"/>
                                                </Canvas>
                                            </Viewbox>
                                        </Button>
                                        <StackPanel DockPanel.Dock="Right"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <Border Background="{Binding SummaryBackground}"
                                                    BorderBrush="{Binding SummaryBorder}"
                                                    BorderThickness="1"
                                                    CornerRadius="4"
                                                    Padding="8,4"
                                                    Margin="0,0,8,0">
                                                <TextBlock Text="{Binding SummaryText}"
                                                           Foreground="{Binding SummaryForeground}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"/>
                                            </Border>
                                            <Button Content="Старт все"
                                                    Style="{StaticResource StartButton}"
                                                    Tag="{Binding}"
                                                    Click="StartCluster_Click"/>
                                            <Button Content="Стоп все"
                                                    Style="{StaticResource StopButton}"
                                                    Tag="{Binding}"
                                                    Click="StopCluster_Click"/>
                                            <Button Content="Рестарт все"
                                                    Style="{StaticResource InstanceActionButton}"
                                                    Tag="{Binding}"
                                                    Click="RestartCluster_Click"/>
                                            <Button Content="Удалить"
                                                    Style="{StaticResource StopButton}"
                                                    Tag="{Binding}"
                                                    Click="DeleteCluster_Click"/>
                                            <Border Background="#15171B"
                                                    BorderBrush="#30333B"
                                                    BorderThickness="1"
                                                    CornerRadius="5"
                                                    Padding="8,4"
                                                    Margin="8,0,0,0">
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBlock Text="Cluster ID"
                                                               Foreground="{StaticResource DimTextBrush}"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               VerticalAlignment="Center"
                                                               Margin="0,0,8,0"/>
                                                    <TextBlock Text="{Binding ClusterIdDisplay}"
                                                               Foreground="{StaticResource TextBrush}"
                                                               FontFamily="Consolas"
                                                               FontSize="12"
                                                               MinWidth="92"
                                                               VerticalAlignment="Center"/>
                                                    <Button Width="30"
                                                            Height="24"
                                                            Padding="6"
                                                            Margin="8,0,0,0"
                                                            Style="{StaticResource InstanceActionButton}"
                                                            ToolTip="{Binding ClusterIdToggleTooltip}"
                                                            Tag="{Binding}"
                                                            Click="ToggleClusterId_Click">
                                                        <Viewbox Width="14" Height="14">
                                                            <Canvas Width="24" Height="24">
                                                                <Path Data="M1,12 C4.5,5 8.5,3 12,3 C15.5,3 19.5,5 23,12 C19.5,19 15.5,21 12,21 C8.5,21 4.5,19 1,12 Z"
                                                                      Stroke="{StaticResource TextBrush}"
                                                                      StrokeThickness="2"
                                                                      Fill="Transparent"/>
                                                                <Ellipse Canvas.Left="8"
                                                                         Canvas.Top="8"
                                                                         Width="8"
                                                                         Height="8"
                                                                         Stroke="{StaticResource TextBrush}"
                                                                         StrokeThickness="2"
                                                                         Fill="Transparent"/>
                                                            </Canvas>
                                                        </Viewbox>
                                                    </Button>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </DockPanel>

                                    <Border BorderBrush="{StaticResource LineBrush}"
                                            BorderThickness="0,1,0,0"
                                            Margin="0,0,0,10"/>

                                    <ItemsControl ItemsSource="{Binding Instances}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#1A1C21"
                                                        BorderBrush="{Binding CardBorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="6"
                                                        Padding="12"
                                                        Margin="0,0,0,10">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="72"/>
                                                            <ColumnDefinition Width="2.4*"/>
                                                            <ColumnDefinition Width="130"/>
                                                            <ColumnDefinition Width="190"/>
                                                            <ColumnDefinition Width="430"/>
                                                        </Grid.ColumnDefinitions>

                                                        <Border Width="58"
                                                                Height="58"
                                                                CornerRadius="6"
                                                                Background="{Binding AccentBrush}">
                                                            <TextBlock Text="{Binding Initials}"
                                                                       Foreground="{Binding InitialsForeground}"
                                                                       FontSize="18"
                                                                       FontWeight="Bold"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"/>
                                                        </Border>

                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding MapName}" Foreground="{StaticResource TextBrush}" FontSize="16" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Text="{Binding RuntimeDetails}" Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="0,5,0,0" TextTrimming="CharacterEllipsis"/>
                                                        </StackPanel>

                                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                            <TextBlock Text="Статус" Foreground="{StaticResource DimTextBrush}" FontSize="11"/>
                                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                                <Ellipse Width="8" Height="8" Fill="{Binding StatusBrush}" Margin="0,0,6,0"/>
                                                                <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusBrush}" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                            </StackPanel>
                                                        </StackPanel>

                                                        <StackPanel Grid.Column="3" VerticalAlignment="Center">
                                                            <TextBlock Text="Порты" Foreground="{StaticResource DimTextBrush}" FontSize="11"/>
                                                            <TextBlock Text="{Binding Ports}" Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                                        </StackPanel>

                                                        <WrapPanel Grid.Column="4"
                                                                   Width="430"
                                                                   HorizontalAlignment="Right"
                                                                   VerticalAlignment="Center">
                                                            <Button Content="{Binding PrimaryActionText}"
                                                                    Background="{Binding PrimaryActionBackground}"
                                                                    BorderBrush="{Binding PrimaryActionBorder}"
                                                                    Style="{StaticResource InstanceActionButton}"
                                                                    ToolTip="{Binding PrimaryActionTooltip}"
                                                                    Tag="{Binding}"
                                                                    Click="ToggleInstance_Click"/>
                                                            <Button Content="Рестарт"
                                                                    Style="{StaticResource InstanceActionButton}"
                                                                    IsEnabled="{Binding CanRestart}"
                                                                    Tag="{Binding}"
                                                                    Click="RestartInstance_Click"/>
                                                            <Button Content="Изменить"
                                                                    Style="{StaticResource InstanceActionButton}"
                                                                    IsEnabled="{Binding CanEdit}"
                                                                    Tag="{Binding}"
                                                                    Click="EditMap_Click"/>
                                                            <Button Content="Команда"
                                                                    Style="{StaticResource InstanceActionButton}"
                                                                    Tag="{Binding}"
                                                                    Click="ShowCommand_Click"/>
                                                            <Button Content="RCON"
                                                                    Style="{StaticResource InstanceActionButton}"
                                                                    Tag="{Binding}"
                                                                    Click="OpenRcon_Click"/>
                                                            <Button Content="Удалить"
                                                                    Style="{StaticResource StopButton}"
                                                                    Tag="{Binding}"
                                                                    Click="DeleteMap_Click"/>
                                                        </WrapPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>

        <Grid x:Name="ClusterSettingsOverlay"
              Grid.RowSpan="2"
              Visibility="Collapsed"
              Background="#CC090A0D">
            <Border Width="620"
                    Background="#17191E"
                    BorderBrush="#3A404A"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Настройки кластера"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="24"
                               FontWeight="Bold"/>
                    <TextBlock Text="Пока приложение работает с одним кластером. Cluster ID используется при запуске каждой карты через -clusterid."
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="13"
                               TextWrapping="Wrap"
                               Margin="0,8,0,20"/>

                    <TextBlock Text="Название профиля"
                               Foreground="{StaticResource DimTextBrush}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <TextBox x:Name="ClusterNameTextBox"
                             Style="{StaticResource SettingsTextBox}"
                             Margin="0,0,0,14"/>

                    <TextBlock Text="Cluster ID"
                               Foreground="{StaticResource DimTextBrush}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <TextBox x:Name="ClusterIdTextBox"
                             Style="{StaticResource SettingsTextBox}"
                             Margin="0,0,0,14"/>

                    <TextBlock Text="Общие моды"
                               Foreground="{StaticResource DimTextBrush}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <TextBox x:Name="ClusterModsTextBox"
                             Style="{StaticResource SettingsTextBox}"
                             Margin="0,0,0,6"/>
                    <TextBlock Text="Например: 947033,939228,952945. Пробелы можно писать, приложение потом нормализует список."
                               Foreground="{StaticResource DimTextBrush}"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Margin="0,0,0,14"/>

                    <TextBlock Text="Базовые флаги запуска"
                               Foreground="{StaticResource DimTextBrush}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <TextBox x:Name="ClusterLaunchFlagsTextBox"
                             Style="{StaticResource SettingsTextBox}"
                             Margin="0,0,0,18"/>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Content="Отмена"
                                Style="{StaticResource InstanceActionButton}"
                                Click="CancelClusterSettings_Click"/>
                        <Button Content="Сохранить"
                                Style="{StaticResource StartButton}"
                                Click="SaveClusterSettings_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="MapSettingsOverlay"
              Grid.RowSpan="2"
              Visibility="Collapsed"
              Background="#CC090A0D">
            <Border Width="620"
                    Background="#17191E"
                    BorderBrush="#3A404A"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Настройки карты"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="24"
                               FontWeight="Bold"/>
                    <TextBlock Text="Каждая карта запускается отдельным процессом ArkAscendedServer.exe."
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="13"
                               TextWrapping="Wrap"
                               Margin="0,8,0,20"/>

                    <TextBlock Text="Пресет карты"
                               Foreground="{StaticResource DimTextBrush}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <ComboBox x:Name="MapPresetComboBox"
                              Background="#111318"
                              Foreground="{StaticResource TextBrush}"
                              BorderBrush="#3A3E48"
                              Padding="8,6"
                              Margin="0,0,0,14"
                              SelectionChanged="MapPreset_SelectionChanged">
                        <ComboBoxItem Content="The Island" Tag="TheIsland_WP"/>
                        <ComboBoxItem Content="Scorched Earth" Tag="ScorchedEarth_WP"/>
                        <ComboBoxItem Content="The Center" Tag="TheCenter_WP"/>
                        <ComboBoxItem Content="Aberration" Tag="Aberration_WP"/>
                        <ComboBoxItem Content="Ragnarok" Tag="Ragnarok_WP"/>
                        <ComboBoxItem Content="Custom" Tag=""/>
                    </ComboBox>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="Название в лаунчере" Foreground="{StaticResource DimTextBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <TextBox x:Name="MapDisplayNameTextBox" Style="{StaticResource SettingsTextBox}" Margin="0,0,0,14"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                            <TextBlock Text="Код карты" Foreground="{StaticResource DimTextBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <TextBox x:Name="MapCodeTextBox" Style="{StaticResource SettingsTextBox}" Margin="0,0,0,14"/>
                        </StackPanel>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="SessionName" Foreground="{StaticResource DimTextBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <TextBox x:Name="MapSessionNameTextBox" Style="{StaticResource SettingsTextBox}" Margin="0,0,0,14"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                            <TextBlock Text="AltSaveDirectoryName" Foreground="{StaticResource DimTextBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <TextBox x:Name="MapSaveDirectoryTextBox" Style="{StaticResource SettingsTextBox}" Margin="0,0,0,14"/>
                        </StackPanel>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="Port" Foreground="{StaticResource DimTextBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <TextBox x:Name="MapPortTextBox" Style="{StaticResource SettingsTextBox}" Margin="0,0,0,18"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="10,0,10,0">
                            <TextBlock Text="QueryPort" Foreground="{StaticResource DimTextBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <TextBox x:Name="MapQueryPortTextBox" Style="{StaticResource SettingsTextBox}" Margin="0,0,0,18"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="10,0,0,0">
                            <TextBlock Text="Max players" Foreground="{StaticResource DimTextBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <TextBox x:Name="MapMaxPlayersTextBox" Style="{StaticResource SettingsTextBox}" Margin="0,0,0,18"/>
                        </StackPanel>
                    </Grid>

                    <Border BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="0,1,0,0"
                            Margin="0,0,0,16"/>

                    <CheckBox x:Name="MapRconEnabledCheckBox"
                              Content="Включить RCON для этой карты"
                              Style="{StaticResource SettingsCheckBox}"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="RCONPort" Foreground="{StaticResource DimTextBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <TextBox x:Name="MapRconPortTextBox" Style="{StaticResource SettingsTextBox}" Margin="0,0,0,18"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                            <TextBlock Text="ServerAdminPassword" Foreground="{StaticResource DimTextBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <PasswordBox x:Name="MapAdminPasswordBox" Style="{StaticResource SettingsPasswordBox}" Margin="0,0,0,18"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Content="Отмена"
                                Style="{StaticResource InstanceActionButton}"
                                Click="CancelMapSettings_Click"/>
                        <Button Content="Сохранить"
                                Style="{StaticResource StartButton}"
                                Click="SaveMapSettings_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="RconCommandOverlay"
              Grid.RowSpan="2"
              Visibility="Collapsed"
              Background="#CC090A0D">
            <Border Width="660"
                    Background="#17191E"
                    BorderBrush="#3A404A"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock x:Name="RconMapTitleTextBlock"
                               Text="RCON"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="24"
                               FontWeight="Bold"/>
                    <TextBlock x:Name="RconEndpointTextBlock"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="13"
                               Margin="0,8,0,18"/>

                    <WrapPanel Margin="0,0,0,14">
                        <Button Content="SaveWorld"
                                Style="{StaticResource InstanceActionButton}"
                                Click="RconSaveWorld_Click"/>
                        <Button Content="ListPlayers"
                                Style="{StaticResource InstanceActionButton}"
                                Click="RconListPlayers_Click"/>
                        <Button Content="Broadcast"
                                Style="{StaticResource InstanceActionButton}"
                                Click="RconBroadcast_Click"/>
                    </WrapPanel>

                    <TextBlock Text="Команда"
                               Foreground="{StaticResource DimTextBrush}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <TextBox x:Name="RconCommandTextBox"
                             Style="{StaticResource SettingsTextBox}"
                             Margin="0,0,0,14"/>

                    <TextBlock Text="Ответ сервера"
                               Foreground="{StaticResource DimTextBrush}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <TextBox x:Name="RconOutputTextBox"
                             Style="{StaticResource SettingsTextBox}"
                             Height="180"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Margin="0,0,0,18"/>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Content="Закрыть"
                                Style="{StaticResource InstanceActionButton}"
                                Click="CancelRcon_Click"/>
                        <Button Content="Отправить"
                                Style="{StaticResource StartButton}"
                                Click="SendRconCommand_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="GameSettingsOverlay"
              Grid.RowSpan="2"
              Visibility="Collapsed"
              Background="#CC090A0D">
            <Border Width="820"
                    MaxHeight="760"
                    Background="#17191E"
                    BorderBrush="#3A404A"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Настройки игры"
                                   Foreground="{StaticResource TextBrush}"
                                   FontSize="24"
                                   FontWeight="Bold"/>
                        <TextBlock x:Name="GameConfigPathTextBlock"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,18"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="Основные множители"
                                       Foreground="{StaticResource DimTextBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="Множитель ресурсов" Foreground="{StaticResource DimTextBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <TextBox x:Name="HarvestAmountTextBox" Style="{StaticResource SettingsTextBox}" Margin="0,0,0,14"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="10,0,10,0">
                                    <TextBlock Text="Множитель опыта" Foreground="{StaticResource DimTextBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <TextBox x:Name="XpMultiplierTextBox" Style="{StaticResource SettingsTextBox}" Margin="0,0,0,14"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Margin="10,0,0,0">
                                    <TextBlock Text="Скорость приручения" Foreground="{StaticResource DimTextBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <TextBox x:Name="TamingSpeedTextBox" Style="{StaticResource SettingsTextBox}" Margin="0,0,0,14"/>
                                </StackPanel>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="Множитель стака" Foreground="{StaticResource DimTextBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <TextBox x:Name="ItemStackSizeTextBox" Style="{StaticResource SettingsTextBox}" Margin="0,0,0,14"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="10,0,10,0">
                                    <TextBlock Text="Автосохранение, минут" Foreground="{StaticResource DimTextBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <TextBox x:Name="AutoSaveMinutesTextBox" Style="{StaticResource SettingsTextBox}" Margin="0,0,0,14"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Margin="10,0,0,0">
                                    <TextBlock Text="DifficultyOffset" Foreground="{StaticResource DimTextBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <TextBox x:Name="DifficultyOffsetTextBox" Style="{StaticResource SettingsTextBox}" Margin="0,0,0,14"/>
                                </StackPanel>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="Скорость цикла дня" Foreground="{StaticResource DimTextBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <TextBox x:Name="DayCycleSpeedTextBox" Style="{StaticResource SettingsTextBox}" Margin="0,0,0,18"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="10,0,10,0">
                                    <TextBlock Text="Скорость ночи" Foreground="{StaticResource DimTextBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <TextBox x:Name="NightSpeedTextBox" Style="{StaticResource SettingsTextBox}" Margin="0,0,0,18"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Margin="10,0,0,0">
                                    <TextBlock Text="Радиус запрета ресурсов" Foreground="{StaticResource DimTextBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <TextBox x:Name="StructurePreventRadiusTextBox" Style="{StaticResource SettingsTextBox}" Margin="0,0,0,18"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Удобство сервера"
                                       Foreground="{StaticResource DimTextBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Margin="0,2,0,10"/>
                            <WrapPanel>
                                <CheckBox x:Name="ShowMapPlayerLocationCheckBox" Content="Показывать игроков на карте" Style="{StaticResource SettingsCheckBox}"/>
                                <CheckBox x:Name="AllowThirdPersonCheckBox" Content="Третье лицо" Style="{StaticResource SettingsCheckBox}"/>
                                <CheckBox x:Name="ServerCrosshairCheckBox" Content="Прицел" Style="{StaticResource SettingsCheckBox}"/>
                                <CheckBox x:Name="StructurePickupCheckBox" Content="Подбор построек" Style="{StaticResource SettingsCheckBox}"/>
                            </WrapPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="Время подбора построек" Foreground="{StaticResource DimTextBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <TextBox x:Name="StructurePickupTimeTextBox" Style="{StaticResource SettingsTextBox}" Margin="0,0,0,18"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Разведение и ферма"
                                       Foreground="{StaticResource DimTextBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Margin="0,2,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="Интервал спаривания" Foreground="{StaticResource DimTextBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <TextBox x:Name="MatingIntervalTextBox" Style="{StaticResource SettingsTextBox}" Margin="0,0,0,14"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="10,0,10,0">
                                    <TextBlock Text="Скорость вылупления" Foreground="{StaticResource DimTextBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <TextBox x:Name="EggHatchSpeedTextBox" Style="{StaticResource SettingsTextBox}" Margin="0,0,0,14"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Margin="10,0,0,0">
                                    <TextBlock Text="Скорость взросления" Foreground="{StaticResource DimTextBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <TextBox x:Name="BabyMatureSpeedTextBox" Style="{StaticResource SettingsTextBox}" Margin="0,0,0,14"/>
                                </StackPanel>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="Интервал заботы" Foreground="{StaticResource DimTextBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <TextBox x:Name="BabyCuddleIntervalTextBox" Style="{StaticResource SettingsTextBox}" Margin="0,0,0,14"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="10,0,10,0">
                                    <TextBlock Text="Сила импринта" Foreground="{StaticResource DimTextBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <TextBox x:Name="BabyImprintAmountTextBox" Style="{StaticResource SettingsTextBox}" Margin="0,0,0,14"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Margin="10,0,0,0">
                                    <TextBlock Text="Рост растений" Foreground="{StaticResource DimTextBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <TextBox x:Name="CropGrowthSpeedTextBox" Style="{StaticResource SettingsTextBox}" Margin="0,0,0,14"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,18,0,0">
                        <Button Content="Отмена"
                                Style="{StaticResource InstanceActionButton}"
                                Click="CancelGameSettings_Click"/>
                        <Button Content="Сохранить"
                                Style="{StaticResource StartButton}"
                                Click="SaveGameSettings_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Grid x:Name="GamePickerOverlay"
              Grid.RowSpan="2"
              Background="#CC090A0D">
            <Border Width="560"
                    Background="#17191E"
                    BorderBrush="#3A404A"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Выберите игру"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="26"
                               FontWeight="Bold"/>
                    <TextBlock Text="Путь к exe будет настраиваться отдельно через красную кнопку в панели инструментов."
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="13"
                               TextWrapping="Wrap"
                               Margin="0,8,0,22"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Style="{StaticResource GameChoiceButton}"
                                Margin="0,0,10,0"
                                Click="SelectAscended_Click">
                            <StackPanel>
                                <TextBlock Text="ARK Survival Ascended"
                                           Foreground="{StaticResource TextBrush}"
                                           FontSize="17"
                                           FontWeight="Bold"/>
                                <TextBlock Text="Рабочий режим"
                                           Foreground="#6EE7B7"
                                           FontSize="13"
                                           Margin="0,8,0,0"/>
                                <TextBlock Text="Кластеры и карты будут собираться под ASA dedicated server."
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Margin="0,8,0,0"/>
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="1"
                                Style="{StaticResource GameChoiceButton}"
                                Margin="10,0,0,0"
                                IsEnabled="False">
                            <StackPanel>
                                <TextBlock Text="ARK Survival Evolved"
                                           FontSize="17"
                                           FontWeight="Bold"/>
                                <TextBlock Text="Позже"
                                           FontSize="13"
                                           Margin="0,8,0,0"/>
                                <TextBlock Text="Оставляем место в интерфейсе, но пока не включаем поддержку."
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Margin="0,8,0,0"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
